rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null || resource.data.userType == 'Distributor' || resource.data.user_type == 'Distributor';
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount'])
      );
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /userFollowing/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /userFollowers/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /post/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /likes/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /saves/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /comments/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /shares/{docId} {
      allow read, write: if request.auth != null;
    }

    match /category/{docId} {
      allow read, write: if request.auth != null;
    }

    match /reels/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
